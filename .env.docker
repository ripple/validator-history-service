# ============================================
# Validator History Service - Docker Compose
# ============================================
# This is a sample .env file for Docker Compose
# Copy this to .env: cp .env.docker .env

# --------------------------------------------
# Node Environment
# --------------------------------------------
NODE_ENV=production

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# Note: DB_HOST is overridden to 'postgres' in docker-compose.yaml
DB_CLIENT=pg
DB_USER=vhs_user
DB_PASSWORD=vhs_password
DB_DATABASE=validator_history
ACQUIRE_CONNECTION_TIMEOUT=60000

# --------------------------------------------
# Server Configuration
# --------------------------------------------
# Note: These are overridden in docker-compose.yaml for containers
PORT=3000
ADDR=0.0.0.0

# --------------------------------------------
# XRPL Network Configuration
# --------------------------------------------
# Rippled Server with access to manifest command
RIPPLED_RPC_ADMIN=https://xrpl.ws/

# Mainnet entry point for crawler (without https://)
MAINNET_P2P_ENTRY=s1.ripple.com

# Validator lists for mainnet (without https://)
MAINNET_UNL=vl.ripple.com

# --------------------------------------------
# GeoIP Configuration (Optional)
# --------------------------------------------
# Leave empty if you don't have MaxMind credentials
MAXMIND_USER=
MAXMIND_KEY=

